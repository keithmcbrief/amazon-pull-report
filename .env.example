# amazon-pull-report — credentials template
#
# Copy this file to ONE of these locations (in priority order):
#   1. <project-root>/.env       — recommended; the skill walks up from CWD to find it.
#   2. ~/.config/amazon-pull-report/.env  — user-level, shared across projects.
#
# The skill folder itself is NOT a recommended location — keep credentials
# outside any code that might be distributed or copied.
#
# Then fill in the four required values below.
# Never commit a filled-in .env to git. Add `.env` to .gitignore.

# ==== LWA app credentials (from Seller Central → Develop Apps) ====

# Looks like: amzn1.application-oa2-client.aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
LWA_CLIENT_ID=

# A long hex string. Treat like a password.
LWA_CLIENT_SECRET=

# ==== Seller-specific credentials ====

# Looks like: Atzr|IwEBIA...   (long string starting with Atzr|)
# This is shown ONCE when you self-authorize the app. Save it somewhere safe.
SP_API_REFRESH_TOKEN=

# ==== Marketplace + region ====

# Marketplace ID (just one). Common ones:
#   US  = ATVPDKIKX0DER
#   CA  = A2EUQ1WTGCTBG2
#   MX  = A1AM78C64UM0Y8
#   UK  = A1F83G8C2ARO7P
#   DE  = A1PA6795UKMFR9
#   FR  = A13V1IB3VIYZZH
#   IT  = APJ6JRA9NG5V4
#   ES  = A1RKKUPIHCS9HS
#   JP  = A1VC38T7YXB528
#   AU  = A39IBJ37TRP1C6
SP_API_MARKETPLACE_ID=ATVPDKIKX0DER

# Region — must match the marketplace.
#   NA  = North America (US, CA, MX, BR)
#   EU  = Europe (UK, DE, FR, IT, ES, NL, SE, PL, TR, AE, IN, SA, EG)
#   FE  = Far East (JP, AU, SG)
SP_API_REGION=NA
